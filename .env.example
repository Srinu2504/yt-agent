# Required — get free at console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Optional — paste Netscape cookie format from Chrome
# Export using "Get cookies.txt LOCALLY" Chrome extension on youtube.com
# Needed on Railway to bypass YouTube bot detection
YOUTUBE_COOKIES=

# Optional — defaults shown
MAX_VIDEO_DURATION_MINUTES=60
WHISPER_MODEL=whisper-large-v3-turbo
LLM_MODEL=llama-3.3-70b-versatile
